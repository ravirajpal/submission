# =============================================================================
# InvenTree API Test Configuration
# Target: https://demo.inventree.org
# =============================================================================

# -----------------------------------------------------------------------------
# BASE URL
# -----------------------------------------------------------------------------
BASE_URL=https://demo.inventree.org

# -----------------------------------------------------------------------------
# USER CREDENTIALS
# -----------------------------------------------------------------------------
USER_ALLACCESS_USERNAME=allaccess
USER_ALLACCESS_PASSWORD=nolimits

USER_READER_USERNAME=reader
USER_READER_PASSWORD=readonly

USER_ENGINEER_USERNAME=engineer
USER_ENGINEER_PASSWORD=partsonly

USER_ADMIN_USERNAME=admin
USER_ADMIN_PASSWORD=inventree

# -----------------------------------------------------------------------------
# API ENDPOINTS - Part Module
# -----------------------------------------------------------------------------
ENDPOINT_PART_LIST=/api/part/
ENDPOINT_PART_DETAIL=/api/part/{id}/
ENDPOINT_PART_PRICING=/api/part/{id}/pricing/
ENDPOINT_PART_REQUIREMENTS=/api/part/{id}/requirements/
ENDPOINT_PART_BOM_VALIDATE=/api/part/{id}/bom-validate/

# -----------------------------------------------------------------------------
# API ENDPOINTS - Part Category
# -----------------------------------------------------------------------------
ENDPOINT_PART_CATEGORY_LIST=/api/part/category/
ENDPOINT_PART_CATEGORY_DETAIL=/api/part/category/{id}/

# -----------------------------------------------------------------------------
# API ENDPOINTS - Stock
# -----------------------------------------------------------------------------
ENDPOINT_STOCK_LIST=/api/stock/

# -----------------------------------------------------------------------------
# TEST DATA
# -----------------------------------------------------------------------------
# 101-char IPN string — used in TC_API_PART_CREATE_008 (IPN max length is 100)
TEST_BOUNDARY_IPN_MAX_LENGTH=AAAAABBBBBCCCCCDDDDDEEEEEFFFFFGGGGGHHHHHJJJJJKKKKKLLLLLMMMMMNNNNNOOOOO11111222223333344444555556666677777888889999900000
