# =============================================================================
# InvenTree Automation Framework – Environment Configuration
# Target: https://demo.inventree.org
# Auth  : Basic Authentication (username:password, Base64-encoded)
# Scope : Web UI + API Testing
# =============================================================================

# -----------------------------------------------------------------------------
# BASE URLs
# -----------------------------------------------------------------------------
BASE_URL=https://demo.inventree.org

# -----------------------------------------------------------------------------
# API VERSION & CONTENT TYPE
# -----------------------------------------------------------------------------
API_VERSION=460
API_CONTENT_TYPE=application/json
API_ACCEPT=application/json

# -----------------------------------------------------------------------------
# AUTHENTICATION
# Header format: Authorization: Basic <base64(username:password)>
# -----------------------------------------------------------------------------
API_AUTH_TYPE=Basic

# -----------------------------------------------------------------------------
# USER: allaccess
# Role : View / Create / Edit all pages and items
# Permissions: Full CRUD on all modules
# -----------------------------------------------------------------------------
USER_ALLACCESS_USERNAME=allaccess
USER_ALLACCESS_PASSWORD=nolimits
USER_ALLACCESS_ROLE=full_access

# -----------------------------------------------------------------------------
# USER: reader
# Role : Can view all pages but cannot create, edit or delete database records
# Permissions: Read-only (GET only)
# -----------------------------------------------------------------------------
USER_READER_USERNAME=reader
USER_READER_PASSWORD=readonly
USER_READER_ROLE=read_only

# -----------------------------------------------------------------------------
# USER: engineer
# Role : Can manage parts, view stock, but no access to purchase or sales orders
# Permissions: Parts CRUD + Stock read; No PO/SO access
# -----------------------------------------------------------------------------
USER_ENGINEER_USERNAME=engineer
USER_ENGINEER_PASSWORD=partsonly
USER_ENGINEER_ROLE=parts_engineer

# -----------------------------------------------------------------------------
# USER: admin
# Role : Superuser account - access all areas plus administrator actions
# Permissions: Full system access including admin endpoints
# -----------------------------------------------------------------------------
USER_ADMIN_USERNAME=admin
USER_ADMIN_PASSWORD=inventree
USER_ADMIN_ROLE=superuser

# -----------------------------------------------------------------------------
# API ENDPOINTS - Part Module
# -----------------------------------------------------------------------------
ENDPOINT_PART_LIST=/api/part/
ENDPOINT_PART_DETAIL=/api/part/{id}/
ENDPOINT_PART_PRICING=/api/part/{id}/pricing/
ENDPOINT_PART_REQUIREMENTS=/api/part/{id}/requirements/
ENDPOINT_PART_SERIAL_NUMBERS=/api/part/{id}/serial-numbers/
ENDPOINT_PART_BOM_VALIDATE=/api/part/{id}/bom-validate/
ENDPOINT_PART_BOM_COPY=/api/part/{id}/bom-copy/
ENDPOINT_PART_THUMBS_LIST=/api/part/thumbs/
ENDPOINT_PART_THUMBS_DETAIL=/api/part/thumbs/{id}/
ENDPOINT_PART_INTERNAL_PRICE_LIST=/api/part/internal-price/
ENDPOINT_PART_INTERNAL_PRICE_DETAIL=/api/part/internal-price/{id}/
ENDPOINT_PART_SALE_PRICE_LIST=/api/part/sale-price/
ENDPOINT_PART_SALE_PRICE_DETAIL=/api/part/sale-price/{id}/
ENDPOINT_PART_RELATED_LIST=/api/part/related/
ENDPOINT_PART_RELATED_DETAIL=/api/part/related/{id}/
ENDPOINT_PART_STOCKTAKE_LIST=/api/part/stocktake/
ENDPOINT_PART_STOCKTAKE_DETAIL=/api/part/stocktake/{id}/
ENDPOINT_PART_STOCKTAKE_GENERATE=/api/part/stocktake/generate/
ENDPOINT_PART_TEST_TEMPLATE_LIST=/api/part/test-template/
ENDPOINT_PART_TEST_TEMPLATE_DETAIL=/api/part/test-template/{id}/

# -----------------------------------------------------------------------------
# API ENDPOINTS - Part Category Module
# -----------------------------------------------------------------------------
ENDPOINT_PART_CATEGORY_LIST=/api/part/category/
ENDPOINT_PART_CATEGORY_DETAIL=/api/part/category/{id}/
ENDPOINT_PART_CATEGORY_TREE=/api/part/category/tree/
ENDPOINT_PART_CATEGORY_PARAMETERS_LIST=/api/part/category/parameters/
ENDPOINT_PART_CATEGORY_PARAMETERS_DETAIL=/api/part/category/parameters/{id}/

# -----------------------------------------------------------------------------
# API ENDPOINTS - BOM Module
# -----------------------------------------------------------------------------
ENDPOINT_BOM_LIST=/api/bom/
ENDPOINT_BOM_DETAIL=/api/bom/{id}/
ENDPOINT_BOM_VALIDATE=/api/bom/{id}/validate/
ENDPOINT_BOM_SUBSTITUTE_LIST=/api/bom/substitute/
ENDPOINT_BOM_SUBSTITUTE_DETAIL=/api/bom/substitute/{id}/

# -----------------------------------------------------------------------------
# API ENDPOINTS - Parameter Module
# -----------------------------------------------------------------------------
ENDPOINT_PARAMETER_LIST=/api/parameter/
ENDPOINT_PARAMETER_DETAIL=/api/parameter/{id}/
ENDPOINT_PARAMETER_TEMPLATE_LIST=/api/parameter/template/
ENDPOINT_PARAMETER_TEMPLATE_DETAIL=/api/parameter/template/{id}/

# -----------------------------------------------------------------------------
# API ENDPOINTS - Attachment Module
# -----------------------------------------------------------------------------
ENDPOINT_ATTACHMENT_LIST=/api/attachment/
ENDPOINT_ATTACHMENT_DETAIL=/api/attachment/{id}/

# -----------------------------------------------------------------------------
# API ENDPOINTS - Stock (referenced by Part tests)
# -----------------------------------------------------------------------------
ENDPOINT_STOCK_LIST=/api/stock/
ENDPOINT_STOCK_DETAIL=/api/stock/{id}/

# -----------------------------------------------------------------------------
# PAGINATION DEFAULTS
# -----------------------------------------------------------------------------
DEFAULT_PAGE_LIMIT=10
DEFAULT_PAGE_OFFSET=0
MAX_PAGE_LIMIT=100

# -----------------------------------------------------------------------------
# TEST DATA - Part
# -----------------------------------------------------------------------------
TEST_PART_NAME_PREFIX=TC_Part_
TEST_PART_DESCRIPTION=Test part created by automation
TEST_PART_IPN_PREFIX=TC-IPN-
TEST_PART_UNITS=pcs
TEST_PART_MINIMUM_STOCK=5
TEST_PART_LINK=https://example.com/datasheet.pdf
TEST_PART_KEYWORDS=test automation resistor

# Boolean flag defaults for part types
TEST_PART_ACTIVE=true
TEST_PART_VIRTUAL=false
TEST_PART_ASSEMBLY=false
TEST_PART_COMPONENT=true
TEST_PART_TRACKABLE=false
TEST_PART_PURCHASEABLE=true
TEST_PART_SALABLE=false
TEST_PART_TESTABLE=false
TEST_PART_IS_TEMPLATE=false
TEST_PART_LOCKED=false

# -----------------------------------------------------------------------------
# TEST DATA - Part Category
# -----------------------------------------------------------------------------
TEST_CATEGORY_NAME_PREFIX=TC_Category_
TEST_CATEGORY_DESCRIPTION=Test category created by automation

# -----------------------------------------------------------------------------
# TEST DATA - BOM
# -----------------------------------------------------------------------------
TEST_BOM_QUANTITY=2
TEST_BOM_REFERENCE=R1
TEST_BOM_OVERAGE=0.1
TEST_BOM_NOTE=Automation BOM note
TEST_BOM_CONSUMABLE=false
TEST_BOM_INHERITED=false

# -----------------------------------------------------------------------------
# TEST DATA - Invalid / Boundary Values
# -----------------------------------------------------------------------------
TEST_INVALID_ID=999999999
TEST_INVALID_STRING=!!INVALID##
TEST_BOUNDARY_IPN_MAX_LENGTH=AAAAABBBBBCCCCCDDDDDEEEEEFFFFFGGGGGHHHHHJJJJJKKKKKLLLLLMMMMMNNNNNOOOOO11111222223333344444555556666677777888889999900000
# ^--- 101 chars (IPN max is 100)
TEST_EMPTY_STRING=
TEST_NEGATIVE_QUANTITY=-1
TEST_ZERO_QUANTITY=0
TEST_VERY_LARGE_QUANTITY=999999999

# -----------------------------------------------------------------------------
# WEB UI - Browser Configuration
# -----------------------------------------------------------------------------
BROWSER=chromium
HEADLESS=false
BROWSER_TIMEOUT_MS=30000

# -----------------------------------------------------------------------------
# WEB UI - Page URLs
# -----------------------------------------------------------------------------
UI_LOGIN_URL=https://demo.inventree.org/web/login/

# -----------------------------------------------------------------------------
# REPORTING & LOGGING
# -----------------------------------------------------------------------------
REPORT_OUTPUT_DIR=./reports
LOG_LEVEL=INFO
SCREENSHOT_ON_FAILURE=true
VIDEO_RECORD=false

# -----------------------------------------------------------------------------
# TIMEOUTS
# -----------------------------------------------------------------------------

# -----------------------------------------------------------------------------
# ENVIRONMENT METADATA
# -----------------------------------------------------------------------------
ENV_NAME=demo
ENV_DESCRIPTION=InvenTree public demo environment
ENV_VERSION=460
PROJECT=InvenTree Part Module API Tests